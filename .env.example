# ==================== SERVER ====================
PORT=3001
NODE_ENV=production

# ==================== DATABASE ====================
# PostgreSQL connection string (Railway provides this automatically)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/news_hub_poland

# ==================== JWT AUTHENTICATION ====================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:3000

# ==================== NEWS APIs ====================
# Get free API key from https://newsapi.org
NEWSAPI_KEY=your-newsapi-key-here

# Get free API key from https://gnews.io
GNEWS_API_KEY=your-gnews-api-key-here

# ==================== TRANSLATION ====================
# Option 1: OpenAI (Recommended for quality)
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Option 2: Google Translate (Fallback)
# Get API key from Google Cloud Console
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key-here

# ==================== OPTIONAL: REDIS CACHE ====================
# For caching frequently accessed articles
REDIS_URL=redis://localhost:6379

# ==================== OPTIONAL: EMAIL ====================
# For sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== LOGGING ====================
LOG_LEVEL=info
