{
  "name": "news-hub-poland",
  "version": "1.0.0",
  "description": "Multilingual Polish news aggregator - Full-stack monolithic application",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:frontend": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "news",
    "aggregator",
    "multilingual",
    "poland",
    "translation",
    "full-stack"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.8.0",
  "axios": "1.6.5",
  "bcryptjs": "2.4.3",
  "cors": "2.8.5",
  "dotenv": "16.3.1",
  "express": "4.18.2",
  "express-static-gzip": "2.1.1",
  "express-validator": "7.0.0",
  "jsonwebtoken": "9.0.2",
  "node-cron": "3.0.2",
  "redis": "4.6.12",
  "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prisma": "5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
